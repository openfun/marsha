    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.13.3",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "<8.0.0",
    "eslint": "8.57.0",
    "eslint-config-standard-with-typescript": "43.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
