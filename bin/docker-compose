#!/usr/bin/env bash

# Test if we have docker compose v2, and keep quiet if we don't.
if docker compose version > /dev/null 2>&1; then
  dockercompose="docker compose"
else
  dockercompose="docker-compose"
fi

if [[ "${BASH_SOURCE[0]}" != "${0}" ]] ; then
    export dockercompose
else
    $dockercompose "$@"
fi